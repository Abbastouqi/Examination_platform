# ============================================================================
# PrepGenius — Environment Configuration TEMPLATE
# Copy to `.env` and fill in real values:  cp .env.example .env
# This template is committed to git — keep it free of real secrets.
# ============================================================================

# --- General ---------------------------------------------------------------
ENVIRONMENT=development                 # development | staging | production
PROJECT_NAME=PrepGenius
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Security --------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-me-with-a-64-char-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
ALGORITHM=HS256

# --- MongoDB ---------------------------------------------------------------
MONGO_URI=mongodb://mongo:27017
MONGO_DB=prepgenius

# --- Qdrant (Vector DB) ----------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=prepgenius_kb

# --- Redis -----------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- Embeddings ------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_DEVICE=cpu                     # cpu | cuda

# --- Qwen LLM (your server, OpenAI-compatible) -----------------------------
QWEN_BASE_URL=https://your-server/v1
QWEN_API_KEY=not-needed-or-your-key
QWEN_MODEL=Qwen2.5-72B-Instruct
QWEN_TIMEOUT=120
QWEN_MAX_TOKENS=2048
QWEN_TEMPERATURE=0.4

# --- Google OAuth ----------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# --- Email (SMTP) ----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=                           # Gmail: use a 16-char App Password
SMTP_FROM=PrepGenius <no-reply@prepgenius.pk>
FRONTEND_URL=http://localhost:3000

# --- Bootstrap Admin -------------------------------------------------------
ADMIN_EMAIL=admin@prepgenius.pk
ADMIN_PASSWORD=ChangeMe123!

# --- Payments: JazzCash ----------------------------------------------------
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=http://localhost:3000/billing/jazzcash/callback
JAZZCASH_ENV=sandbox                     # sandbox | live

# --- Payments: Easypaisa ---------------------------------------------------
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_RETURN_URL=http://localhost:3000/billing/easypaisa/callback
EASYPAISA_ENV=sandbox

# --- Quotas (free plan daily limits) ---------------------------------------
FREE_DAILY_MCQS=20
FREE_DAILY_CHAT=15
FREE_DAILY_MOCKTESTS=1

# --- Uploads ---------------------------------------------------------------
MAX_UPLOAD_MB=50
UPLOAD_DIR=/data/uploads
